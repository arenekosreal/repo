pkgname=llama-cpp
pkgver=b9837
pkgrel=1
pkgdesc="LLM inference in C/C++."
arch=(x86_64)
url=https://llama.app/
license=(MIT)
depends=(glibc libgcc libstdc++ ggml openssl)
makedepends=(git cmake npm)
source=("git+https://github.com/ggml-org/llama.cpp.git#tag=$pkgver"
        "llama-server-system.service"
        "llama-server-user.service")
sha256sums=('30ddb242ec312bbd15c5fb1af6a64327ed3aa3291bb3a478656fb618ac0a4d3c'
            '3f5a9fea92bd6699db9f421d499ac2999447e677a03cfe1f8c68c5197a0c3f70'
            '5d6bb8510211aae4a5a0ad3237e7e7eba5f2d8910c778bb6934bc68df37c638d')
options=(!strip)

prepare() {
    cd "$srcdir/llama.cpp/tools/ui"
    npm install
}

build() {
    cmake -B build -S "$srcdir/llama.cpp" \
        -DCMAKE_BUILD_TYPE=None \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DLLAMA_USE_SYSTEM_GGML=ON \
        -DLLAMA_USE_PREBUILT_UI=OFF \
        -DLLAMA_BUILD_TESTS=OFF
    cmake --build build
}

package() {
    DESTDIR="$pkgdir" cmake --install build
    install -Dvm644 "$srcdir/llama-server-system.service" "$pkgdir/usr/lib/systemd/system/llama-server.service"
    install -Dvm644 "$srcdir/llama-server-user.service" "$pkgdir/usr/lib/systemd/user/llama-server.service"
    install -Dvm644 -t "$pkgdir/usr/share/licenses/$pkgname" \
        "$srcdir/llama.cpp/LICENSE"
    mkdir -p "$pkgdir/usr/share/llama/models"
}
