pkgname=zuban
pkgver=0.8.0
pkgrel=1
pkgdesc="Python Type Checker / Language Server"
arch=(x86_64)
url=https://zubanls.com/
license=(AGPL-3.0-only)
depends=(libgcc glibc)
makedepends=(git cargo cargo-about maturin python python-installer)
source=("git+https://github.com/zubanls/zuban.git#tag=v$pkgver"
        "git+https://github.com/python/typeshed.git"
        "git+https://github.com/typeddjango/django-stubs.git"
        "git+https://github.com/davidhalter/mypy.git")
sha256sums=('01272c96ec7f151cd063b16436de64734d52bdc3836be6a65ba121d5e29d0b11'
            'SKIP'
            'SKIP'
            'SKIP')

prepare() {
    cd "$srcdir/$pkgname"
    git submodule init
    git config submodule.typeshed.url "$srcdir/typeshed"
    git config submodule.crates/zuban_python/tests/mypylike/mypy.url "$srcdir/mypy"
    git config submodule.third_party/django-stubs.url "$srcdir/django-stubs"
    git -c protocol.file.allow=always submodule update
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target host-tuple
}

build() {
    cd "$srcdir/$pkgname/deploy/pypi/zuban"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    # deploy/pypi/zuban/pre-maturin-build.sh
    cargo about generate -o licenses.html about.hbs --fail --manifest-path ../../../Cargo.toml
    maturin build --frozen --release --all-features --out dist --ignore-rust-version
}

package() {
    cd "$srcdir/$pkgname/deploy/pypi/zuban"
    python -m installer --destdir="$pkgdir" dist/*.whl
}
