            'bd9061bb42194460b3683a51e37d54f84bbfdad507a5b3e454c49674846fc038')
# static resources are embedded into binary and cannot be stripped.
options=(!strip)

_strip_files() {
    while read -r f
    do
        case "$(file -Sib "$f")" in
            application/x-sharedlib\;*)        # Libraries (.so)
                strip -v $STRIP_SHARED "$f" ;;
            application/x-archive\;*)          # Libraries (.a)
                strip -v $STRIP_STATIC "$f" ;;
            application/x-executable\;*)       # Binaries
                strip -v $STRIP_BINARIES "$f" ;;
            application/x-pie-executable\;*)   # Relocatable binaries
                strip -v $STRIP_SHARED "$f" ;;
        esac
    done < <(find "$1" -mindepth 1 -type f \( -executable -o -name "*.so" \) -a ! -name "*.sh")
}

prepare() {
    cd "$srcdir/LocalAI"
    export GOPATH="$srcdir"
    make -C backend/cpp/llama-cpp llama.cpp
    make -C backend/go/piper sources/go-piper
    make -C backend/go/stablediffusion-ggml sources/stablediffusion-ggml.cpp
    make -C backend/go/whisper sources/whisper.cpp
    make -C backend/go/acestep-cpp sources/acestep.cpp
    make -C backend/go/voxtral sources/voxtral.c
    go mod download -modcacherw
    cd core/http/react-ui
    npm install
    cd "$srcdir/LocalAI"
    patch -Np1 -i ../0001-disable-installing-extra-tools.diff
    patch -Np1 -i ../0004-avoid-gopiper-flags-being-applied-to-cmake.diff
    patch -Np1 -i ../0005-do-not-clean-build-dir-in-whisper.diff
    patch -Np1 -i ../0006-silero-vad-use-system-onnxruntime.diff
    patch -Np1 -i ../0007-do-not-clean-build-dir-in-stablediffusion-ggml.diff
    patch -Np1 -i ../0008-apply-build-flags.diff
}

build() {
    cd "$srcdir/LocalAI"
    export CGO_CPPFLAGS="${CPPFLAGS}"
    export CGO_CFLAGS="${CFLAGS}"
    export CGO_CXXFLAGS="${CXXFLAGS}"
    export CGO_LDFLAGS="${LDFLAGS}"
    export GOFLAGS="-buildmode=pie -mod=readonly -modcacherw"
    export GOPATH="$srcdir"

    echo "Building main program..."
    make GO_TAGS=stablediffusion,tts,p2p BUILD_TYPE=openblas \
         build

    local backend
    for backend in "${!_backends[@]}"
    do
        local variants_str
        variants_str="$(cut -d , -f 2 -s <<< "${_backends[$backend]}")"
        if [[ -z "$variants_str" ]]
        then
            echo "Building $backend..."
            make -C "backend/$backend" \
                BUILD_TYPE=openblas \
                "${backend##*/}"
        else
            local -a variants=()
            read -r -a variants <<< "$variants_str"
            local variant
            for variant in "${variants[@]}"
            do
                echo "Building $variant of $backend..."
                make -C "backend/$backend" \
                    BUILD_TYPE=openblas \
                    "${backend##*/}-$variant"
            done
        fi
    done
}

package_local-ai() {
    install=$pkgname.install
    optdepends=("local-ai-backend: Packaged backends")
    depends+=(glibc)

    cd "$srcdir/LocalAI"
    mkdir -p "$pkgdir/usr/bin"
    install -Dvm755 "$pkgname" "$pkgdir/usr/bin/$pkgname"
    install -Dvm644 "$srcdir/$pkgbase.service" "$pkgdir/usr/lib/systemd/system/$pkgbase.service"
    install -Dvm644 ".env" "$pkgdir/usr/share/doc/$pkgbase/$pkgbase.env"
    install -Dvm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgbase/LICENSE"
}

package_local-ai-backend-llama-cpp-openblas() {
    pkgdesc+=" (llama-cpp backend with openblas optimization)"
    groups=(local-ai-backend)
    provides=(local-ai-backend-llama-cpp)
    conflicts=(local-ai-backend-llama-cpp)
    depends+=(abseil-cpp glibc grpc libgcc libgomp libstdc++ openblas protobuf)

    cd "$srcdir/LocalAI"
    local -a variants
    read -r -a variants <<< "$(cut -d , -f 2 -s <<< "${_backends[cpp/llama-cpp]}")"
    install -Dvm755 -t "$pkgdir/usr/lib/$pkgbase/backends/llama-cpp" \
        "${variants[@]/#/backend/cpp/llama-cpp/llama-cpp-}" \
        "backend/cpp/llama-cpp/run.sh"
    _strip_files "$pkgdir/usr/lib/$pkgbase/backends/llama-cpp"
    install -Dvm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

