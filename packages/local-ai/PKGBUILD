# Format: [directory]="pkgsuffix[,variants...]"
declare -Ag _backends=(
    [cpp/llama-cpp]="local-ai-backend-llama-cpp-openblas,avx avx2 avx512 fallback grpc rpc-server"
    [go/acestep-cpp]=local-ai-backend-acestep-cpp-openblas
    [go/local-store]=local-ai-backend-local-store
    [go/opus]=local-ai-backend-opus
    [go/piper]=local-ai-backend-piper
    [go/silero-vad]=local-ai-backend-silero-vad
    [go/stablediffusion-ggml]=local-ai-backend-stablediffusion-ggml
    [go/voxtral]=local-ai-backend-voxtral-openblas
    [go/whisper]=local-ai-backend-whisper-openblas)

pkgbase=local-ai
pkgname=(local-ai "${_backends[@]%%,*}")
pkgver=4.1.0
pkgrel=1
pkgdesc="The free, Open Source alternative to OpenAI, Claude and others."
arch=(x86_64)
url=https://localai.io/
license=(MIT)
depends=(bash)
makedepends=(cmake git go go.rice abseil-cpp grpc protobuf protoc-gen-go protoc-gen-go-grpc
             blas-openblas blas64-openblas onnxruntime opus npm)
source=("git+https://github.com/mudler/LocalAI.git#tag=v$pkgver"
        "local-ai.service"
        "0001-disable-installing-extra-tools.diff"
        "0004-avoid-gopiper-flags-being-applied-to-cmake.diff"
        "0005-do-not-clean-build-dir-in-whisper.diff"
        "0006-silero-vad-use-system-onnxruntime.diff"
        "0007-do-not-clean-build-dir-in-stablediffusion-ggml.diff"
        "0008-apply-build-flags.diff")
sha256sums=('af7b7a25fdc93710de2e87a9f1e2981f5895d784181d5f23d3a53b81cdebec3e'
            '2cbecd8267b3807e88feffb2239a5cdfd3912fe1e78aa856a781cb39154536d0'
            '2771f64577862476a2e699c74d6eb0e3a537743c1784535cfb268f827ce6b18b'
            'fc1fd76b8af6be5db97e0e0ddccd09d9361ef69f12f9eab99308340634684704'
            '7b0d306870ddc49d41a7a37f13d1a8c89fc310b82c70de5c1f1b9769e87e7a90'
