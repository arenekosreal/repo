# Contributor: robertfoster

pkgbase=local-ai
pkgname=(local-ai local-ai-backend-llama-cpp local-ai-backend-cloud-proxy)
pkgver=4.5.0
pkgrel=1
pkgdesc="The free, Open Source alternative to OpenAI, Claude and others."
arch=(x86_64)
url=https://localai.io/
license=(MIT)
makedepends=(cmake git go go.rice abseil-cpp grpc protobuf protoc-gen-go protoc-gen-go-grpc
             blas-openblas blas64-openblas npm nodejs-lts-jod vulkan-headers spirv-headers
             vulkan-icd-loader shaderc nlohmann-json)
source=("git+https://github.com/mudler/LocalAI.git#tag=v$pkgver"
        "git+https://github.com/ggerganov/llama.cpp.git#commit=73618f27a801c0b8614ceaf3547d3c2a99baae14"
        "local-ai.service")
sha256sums=('41193233508b7eea639a5340f0d98cd75a49697b3be71cb77448725404758393'
            'cb4e31ada1280c92ce69f4b89f7b254e53bfe2266808147a2175301c788e86d2'
            '2cbecd8267b3807e88feffb2239a5cdfd3912fe1e78aa856a781cb39154536d0')

prepare() {
    cd "$srcdir/LocalAI"

    #backend/cpp/llama-cpp/prepare.sh
    cp -a "$srcdir/llama.cpp/tools/server" "$srcdir/llama.cpp/tools/grpc-server"
    cp -t "$srcdir/llama.cpp/tools/grpc-server" "backend/cpp/llama-cpp/CMakeLists.txt" "backend/cpp/llama-cpp/grpc-server.cpp"
    # shellcheck disable=SC2016
    sed -i -e '/add_executable/ s/ json.hpp httplib.h//' \
           -e '/target_link_libraries(${TARGET}/ a nlohmann_json::nlohmann_json' \
           -e '/target_link_libraries(${TARGET}/ a cpp-httplib' \
           -e '/find_package(absl/ i find_package(nlohmann_json CONFIG REQUIRED)' \
           -e "s|../../../../../..|$srcdir/LocalAI|" \
        "$srcdir/llama.cpp/tools/grpc-server/CMakeLists.txt"
    grep -q "add_subdirectory(grpc-server)" "$srcdir/llama.cpp/tools/CMakeLists.txt" || \
        echo "add_subdirectory(grpc-server)" >> "$srcdir/llama.cpp/tools/CMakeLists.txt"

    echo "Generating protobuf code..."
    mkdir -p pkg/grpc/proto/
    protoc --experimental_allow_proto3_optional -Ibackend/ \
        --go_out=pkg/grpc/proto/ --go_opt=paths=source_relative \
        --go-grpc_out=pkg/grpc/proto/ --go-grpc_opt=paths=source_relative \
        backend/backend.proto

    echo "Fetching dependencies..."
    export GOPATH="$srcdir"
    go mod download -modcacherw
    cd "$srcdir/LocalAI/core/http/react-ui"
    npm install
}

build() {
    export CGO_CPPFLAGS="${CPPFLAGS}"
    export CGO_CFLAGS="${CFLAGS}"
    export CGO_CXXFLAGS="${CXXFLAGS}"
    export CGO_LDFLAGS="${LDFLAGS}"
    export GOFLAGS="-buildmode=pie -mod=readonly -modcacherw"
    export GOPATH="$srcdir"

    cd "$srcdir/LocalAI/core/http/react-ui"
    echo "Building frontend..."
    npm run build

    local tags="stablediffusion,tts,p2p"

    cd "$srcdir/LocalAI"
    echo "Building main program..."
    go build -ldflags "-s -w -bindnow -compressdwarf=false -linkmode external -X \"github.com/mudler/LocalAI/internal.Version=$(git describe --always --tags)\" -X \"github.com/mudler/LocalAI/internal.Commit=$(git rev-parse HEAD)\"" -tags "$tags" -o local-ai ./cmd/local-ai

    cd "$srcdir"
    local ggml_common_args=(-DCMAKE_BUILD_TYPE=None -DGGML_NATIVE=OFF -DGGML_BLAS=ON -DGGML_BLAS_VENDOR=OpenBLAS -DBUILD_SHARED_LIBS=OFF
        -DGGML_BUILD_TESTS=OFF -DGGML_BUILD_EXAMPLES=OFF -DGGML_VULKAN=ON)
    local ggml_avx2_args=(-DGGML_AVX=ON -DGGML_AVX2=ON -DGGML_AVX512=OFF -DGGML_FMA=ON -DGGML_F16C=ON)
    local ggml_avx_args=(-DGGML_AVX=ON -DGGML_AVX2=OFF -DGGML_AVX512=OFF -DGGML_FMA=OFF -DGGML_F16C=OFF)
    local ggml_avx512_args=(-DGGML_AVX=ON -DGGML_AVX2=OFF -DGGML_AVX512=ON -DGGML_FMA=ON -DGGML_F16C=ON)
    local ggml_fallback_args=(-DGGML_AVX=OFF -DGGML_AVX2=OFF -DGGML_AVX512=OFF -DGGML_FMA=OFF -DGGML_F16C=OFF)
    local ggml_grpc_args=("${ggml_fallback_args[@]}" -DGGML_RPC=ON)

    echo "Building llama-cpp backend..."
    mkdir llama-cpp-avx2-build
    cmake -B llama-cpp-avx2-build -S "$srcdir/llama.cpp" \
        "${ggml_avx2_args[@]}" \
        "${ggml_common_args[@]}"
    cmake --build llama-cpp-avx2-build --target grpc-server
    mkdir llama-cpp-avx-build
    cmake -B llama-cpp-avx-build -S "$srcdir/llama.cpp" \
        "${ggml_avx_args[@]}" \
        "${ggml_common_args[@]}"
    cmake --build llama-cpp-avx-build --target grpc-server
    mkdir llama-cpp-avx512-build
    cmake -B llama-cpp-avx512-build -S "$srcdir/llama.cpp" \
        "${ggml_avx512_args[@]}" \
        "${ggml_common_args[@]}"
    cmake --build llama-cpp-avx512-build --target grpc-server
    mkdir llama-cpp-fallback-build
    cmake -B llama-cpp-fallback-build -S "$srcdir/llama.cpp" \
        "${ggml_fallback_args[@]}" \
        "${ggml_common_args[@]}"
    cmake --build llama-cpp-fallback-build --target grpc-server
    mkdir llama-cpp-grpc-build
    cmake -B llama-cpp-grpc-build -S "$srcdir/llama.cpp" \
        "${ggml_grpc_args[@]}" \
        "${ggml_common_args[@]}"
    cmake --build llama-cpp-grpc-build --target grpc-server --target rpc-server

    echo "Building cloud-proxy backend..."
    CGO_ENABLED=0 go build -C "$srcdir/LocalAI/backend/go/cloud-proxy" -ldflags "-s -w -bindnow" -tags "$tags" -o cloud-proxy ./
}

package_local-ai() {
    install=$pkgname.install
    optdepends=("local-ai-backend: Packaged backends")
    depends+=(glibc)
    # static resources are embedded into binary and cannot be stripped.
    options=(!strip)

    cd "$srcdir/LocalAI"
    mkdir -p "$pkgdir/usr/bin"
    install -Dvm755 "$pkgname" "$pkgdir/usr/bin/$pkgname"
    install -Dvm644 "$srcdir/$pkgbase.service" "$pkgdir/usr/lib/systemd/system/$pkgbase.service"
    install -Dvm644 ".env" "$pkgdir/usr/share/doc/$pkgbase/$pkgbase.env"
    install -Dvm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgbase/LICENSE"
}

package_local-ai-backend-llama-cpp() {
    pkgdesc+=" (llama-cpp backend)"
    provides=(local-ai-backend)
    depends+=(abseil-cpp glibc grpc libgcc libgomp libstdc++ openblas protobuf vulkan-icd-loader bash)

    install -Dvm755 -t "$pkgdir/usr/lib/$pkgbase/backends/llama-cpp/" \
        "$srcdir/LocalAI/backend/cpp/llama-cpp/run.sh"
    for variant in avx2 avx avx512 fallback grpc
    do
        install -Dvm755 "$srcdir/llama-cpp-$variant-build/bin/grpc-server" \
            "$pkgdir/usr/lib/$pkgbase/backends/llama-cpp/llama-cpp-$variant"
    done
    install -Dvm644 "$srcdir/LocalAI/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

package_local-ai-backend-cloud-proxy() {
    pkgdesc+=" (cloud-proxy backend)"
    provides=(local-ai-backend)
    depends+=(bash)

    cd "$srcdir/LocalAI"
    install -Dvm755 -t "$pkgdir/usr/lib/$pkgbase/backends/cloud-proxy/" \
        "backend/go/cloud-proxy/cloud-proxy" \
        "backend/go/cloud-proxy/run.sh"
    install -Dvm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
