# static resources are embedded into binary and cannot be stripped.
options=(!strip !lto)

_strip_files() {
    while read -r f
    do
        case "$(file -Sib "$f")" in
            application/x-sharedlib\;*)        # Libraries (.so)
                strip -v $STRIP_SHARED "$f" ;;
            application/x-archive\;*)          # Libraries (.a)
                strip -v $STRIP_STATIC "$f" ;;
            application/x-executable\;*)       # Binaries
                strip -v $STRIP_BINARIES "$f" ;;
            application/x-pie-executable\;*)   # Relocatable binaries
                strip -v $STRIP_SHARED "$f" ;;
        esac
    done < <(find "$1" -mindepth 1 -type f \( -executable -o -name "*.so" \) -a ! -name "*.sh")
}

prepare() {
    cd "$srcdir/LocalAI"
    # Breaks kokoros backend
    git revert --no-commit 0245b33eabd7f9461d4b1ad74027e3a38087c650
    git submodule init
    git config submodule."backend/rust/kokoros/sources/Kokoros".url "$srcdir/Kokoros"
    git config submodule."docs/themes/hugo-theme-relearn".url "$srcdir/hugo-theme-relearn"
    git -c protocol.file.allow=always submodule update
    patch -Np1 -i "$srcdir/0001-Makefile-apply-build-flags-and-skip-installing-tools.diff"
    patch -Np1 -i "$srcdir/0002-acestep-cpp-apply-build-flags.diff"
    patch -Np1 -i "$srcdir/0003-local-store-apply-build-flags.diff"
    patch -Np1 -i "$srcdir/0004-opus-apply-build-flags.diff"
    patch -Np1 -i "$srcdir/0005-piper-apply-build-flags.diff"
    patch -Np1 -i "$srcdir/0006-silero-vad-use-system-onnxruntime.diff"
    patch -Np1 -i "$srcdir/0007-stablediffusion-ggml-do-not-purge-everything.diff"
    patch -Np1 -i "$srcdir/0008-voxtral-apply-build-flags.diff"
    patch -Np1 -i "$srcdir/0009-whisper-do-not-purge-everything.diff"
    patch -Np1 -i "$srcdir/0010-localvqe-apply-build-flags.diff"
    patch -Np1 -i "$srcdir/0011-qwen3-tts-cpp-apply-build-flags.diff"
    patch -Np1 -i "$srcdir/0012-sam3-cpp-do-not-purge-everything.diff"
    patch -Np1 -i "$srcdir/0013-sherpa-onnx-use-system-onnxruntime.diff"
    patch -Np1 -i "$srcdir/0014-vibevoice-cpp-apply-build-flags.diff"
    make -C backend/cpp/llama-cpp llama.cpp
    make -C backend/cpp/ds4 ds4
    make -C backend/go/piper sources/go-piper
    make -C backend/go/stablediffusion-ggml sources/stablediffusion-ggml.cpp
    make -C backend/go/whisper sources/whisper.cpp
    make -C backend/go/acestep-cpp sources/acestep.cpp
    make -C backend/go/voxtral sources/voxtral.c
    make -C backend/go/localvqe sources/LocalVQE
    make -C backend/go/qwen3-tts-cpp sources/qwen3-tts.cpp
    make -C backend/go/sam3-cpp sources/sam3.cpp
    make -C backend/go/sherpa-onnx sources/sherpa-onnx
    make -C backend/go/vibevoice-cpp sources/vibevoice.cpp
    patch -Np1 -i "$srcdir/0015-go-piper-apply-build-flags.diff" -d "backend/go/piper/sources/go-piper/"
    patch -Np1 -i "$srcdir/0016-piper-phonemize-fix-building.diff" -d "backend/go/piper/sources/go-piper/piper-phonemize/"
    export GOPATH="$srcdir"
    go mod download -modcacherw
    cd "$srcdir/LocalAI/core/http/react-ui"
    npm install
    cd "$srcdir/LocalAI/backend/rust/kokoros"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target host-tuple
}

build() {
    cd "$srcdir/LocalAI"
    export CGO_CPPFLAGS="${CPPFLAGS}"
    export CGO_CFLAGS="${CFLAGS}"
    export CGO_CXXFLAGS="${CXXFLAGS}"
    export CGO_LDFLAGS="${LDFLAGS}"
    export GOFLAGS="-buildmode=pie -mod=readonly -modcacherw"
    export GOPATH="$srcdir"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target

    echo "Building main program..."
    make GO_TAGS=stablediffusion,tts,p2p BUILD_TYPE=openblas \
         build
    make -C "backend/cpp/llama-cpp"             BUILD_TYPE=openblas \
        llama-cpp-avx llama-cpp-avx2 llama-cpp-avx512 llama-cpp-fallback llama-cpp-grpc llama-cpp-rpc-server
    make -C "backend/cpp/ds4"                   BUILD_TYPE=openblas grpc-server
    make -C "backend/go/acestep-cpp"            BUILD_TYPE=openblas acestep-cpp
    make -C "backend/go/local-store"            BUILD_TYPE=openblas local-store
    make -C "backend/go/opus"                   BUILD_TYPE=openblas opus
    make -C "backend/go/piper"                  BUILD_TYPE=openblas piper
    make -C "backend/go/silero-vad"             BUILD_TYPE=openblas silero-vad
    make -C "backend/go/stablediffusion-ggml"   BUILD_TYPE=openblas stablediffusion-ggml
    make -C "backend/go/voxtral"                BUILD_TYPE=openblas voxtral
    make -C "backend/go/whisper"                BUILD_TYPE=openblas whisper
    make -C "backend/go/localvqe"               BUILD_TYPE=openblas localvqe
    make -C "backend/go/qwen3-tts-cpp"          BUILD_TYPE=openblas qwen3-tts-cpp
    make -C "backend/go/sam3-cpp"               BUILD_TYPE=openblas sam3-cpp
    make -C "backend/go/sherpa-onnx"            BUILD_TYPE=openblas sherpa-onnx
    make -C "backend/go/vibevoice-cpp"          BUILD_TYPE=openblas vibevoice-cpp
    make -C "backend/rust/kokoros"              BUILD_TYPE=openblas kokoros-grpc
}

package_local-ai() {
    install=$pkgname.install
    optdepends=("local-ai-backend: Packaged backends")
    depends+=(glibc)

    cd "$srcdir/LocalAI"
    mkdir -p "$pkgdir/usr/bin"
    install -Dvm755 "$pkgname" "$pkgdir/usr/bin/$pkgname"
    install -Dvm644 "$srcdir/$pkgbase.service" "$pkgdir/usr/lib/systemd/system/$pkgbase.service"
    install -Dvm644 ".env" "$pkgdir/usr/share/doc/$pkgbase/$pkgbase.env"
    install -Dvm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgbase/LICENSE"
}

package_local-ai-backend-llama-cpp-openblas() {
    pkgdesc+=" (llama-cpp backend with openblas optimization)"
    groups=(local-ai-backend)
    provides=(local-ai-backend-llama-cpp)
    conflicts=(local-ai-backend-llama-cpp)
    depends+=(abseil-cpp glibc grpc libgcc libgomp libstdc++ openblas protobuf)

    cd "$srcdir/LocalAI"
    install -Dvm755 -t "$pkgdir/usr/lib/$pkgbase/backends/llama-cpp" \
        "backend/cpp/llama-cpp/llama-cpp-avx" \
        "backend/cpp/llama-cpp/llama-cpp-avx2" \
        "backend/cpp/llama-cpp/llama-cpp-avx512" \
        "backend/cpp/llama-cpp/llama-cpp-fallback" \
        "backend/cpp/llama-cpp/llama-cpp-grpc" \
        "backend/cpp/llama-cpp/llama-cpp-rpc-server" \
        "backend/cpp/llama-cpp/run.sh"
    _strip_files "$pkgdir/usr/lib/$pkgbase/backends/llama-cpp"
    install -Dvm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

